DATA_DIR=/var/lib/skrapp/data
OUTPUT_DIR=/var/lib/skrapp/out
PORT=8080
WORKER_CONCURRENCY=3
PAGE_LEASE_SECONDS=180
PLAYWRIGHT_DISCOVERY_WAIT_MS=2000
PLAYWRIGHT_PAGE_TIMEOUT_MS=45000
CRAWL4AI_PAGE_TIMEOUT_MS=45000
CRAWL4AI_WAIT_UNTIL=domcontentloaded
CRAWL4AI_DELAY_BEFORE_RETURN_HTML_SECONDS=1.0
CRAWL4AI_PRUNING_THRESHOLD=0.48
CRAWL4AI_MIN_WORD_THRESHOLD=8
CRAWL4AI_EXCLUDED_TAGS=nav,footer,aside,form
